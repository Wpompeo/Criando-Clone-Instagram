<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SocialNetWork" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimaryContainer">@color/gray_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!--Secondary brand color -->
        <item name="colorSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/blue_disabled</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="1">?attr/colorSecondary</item>
    </style>

    <style name="Theme.SocialNetWork" parent="Base.Theme.SocialNetWork" />
</resources>