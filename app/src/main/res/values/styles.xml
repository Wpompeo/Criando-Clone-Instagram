<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--Style margin containers-->
    <style name="Theme.SocialNetWork.FormContainer">
        <item name="android:layout_marginStart">36dp</item>
        <item name="android:layout_marginEnd">36dp</item>
    </style>

    <!--Style forms data input-->
    <style name="Theme.SocialNetWork.FormEditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:background">@drawable/edit_text_background</item>
    </style>

    <style name="Theme.SocialNetWork.FormEditTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">36dp</item>
        <item name="android:layout_marginEnd">36dp</item>
        <item name="android:layout_marginBottom">20dp</item>
    </style>

    <!--Style button enter-->
    <style name="Theme.SocialNetWork.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">0dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>

        <item name="android:layout_marginStart">36dp</item>
        <item name="android:layout_marginEnd">36dp</item>

        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">24dp</item>
        <item name="backgroundTint">@color/button_background</item>
    </style>

    <!--Style line down button-->
    <style name="Theme.SocialNetWork.TextViewBase" parent="Theme.SocialNetWork.FormContainer">
        <item name="android:textColor">@color/gray_text</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>



    </style>


</resources>